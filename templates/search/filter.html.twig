{% extends 'base.html.twig' %}

{% block title %}Filtrer les adhérents — SFB{% endblock %}

{% block body %}
    <h1 class="text-2xl font-semibold text-sfb-grey mb-4">Filtrer les adhérents</h1>

    <div data-controller="search"
         data-search-url-value="{{ path('app_member_search') }}">
        <div class="relative">
            <input type="search"
                   data-search-target="input"
                   data-action="input->search#query"
                   placeholder="Entreprise, contact, ville, SIRET…"
                   autocomplete="off"
                   class="w-full rounded-md border border-gray-300 px-4 py-2.5 pr-10 outline-none focus:border-sfb-green focus:ring-1 focus:ring-sfb-green">
            <button type="button"
                    data-search-target="clear"
                    data-action="search#clear"
                    hidden
                    aria-label="Effacer la recherche"
                    class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        </div>

        <div data-search-target="results" class="mt-4">
            {% include 'search/_results.html.twig' with { results: [], term: '' } %}
        </div>
    </div>
{% endblock %}
