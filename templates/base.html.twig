<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}SFB — Syndicat de la Filière Bois{% endblock %}</title>
        <link rel="icon" href="{{ asset('images/logo.ico') }}">
        {% block stylesheets %}
            {{ encore_entry_link_tags('app') }}
        {% endblock %}

        {% block javascripts %}
            {{ encore_entry_script_tags('app') }}
        {% endblock %}
    </head>
    <body class="min-h-screen bg-sfb-cream text-sfb-grey antialiased flex flex-col">
        {% block navbar %}
            {% include 'partials/_navbar.html.twig' %}
        {% endblock %}

        <main class="flex-1 w-full max-w-7xl mx-auto px-4 py-6">
            {% block flashes %}
                {% for type, messages in app.flashes %}
                    {% for message in messages %}
                        {% include 'partials/_flash.html.twig' with { type: type, message: message } %}
                    {% endfor %}
                {% endfor %}
            {% endblock %}

            {% block body %}{% endblock %}
        </main>
    </body>
</html>
