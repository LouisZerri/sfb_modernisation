{% extends 'base.html.twig' %}

{% block title %}Connexion — SFB{% endblock %}

{% block body %}
    <div class="max-w-md mx-auto mt-8">
        <div class="bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden">
            <div class="bg-sfb-green px-6 py-5 text-center">
                <img src="{{ asset('images/page.png') }}" alt="SFB" class="h-16 mx-auto object-contain">
                <h1 class="mt-3 text-white text-xl font-semibold">Connectez-vous</h1>
            </div>

            <form method="post" class="px-6 py-6 space-y-4">
                {% if error %}
                    <div class="rounded-md border border-red-300 bg-red-50 px-4 py-3 text-sm text-red-800" role="alert">
                        {{ error.messageKey|trans(error.messageData, 'security') }}
                    </div>
                {% endif %}

                <div>
                    <label for="username" class="block text-sm font-medium text-sfb-grey mb-1">Email</label>
                    <input type="email" value="{{ last_username }}" name="_username" id="username"
                           autocomplete="email" required autofocus
                           class="w-full rounded-md border border-gray-300 px-3 py-2 focus:border-sfb-green focus:ring-1 focus:ring-sfb-green outline-none">
                </div>

                <div>
                    <label for="password" class="block text-sm font-medium text-sfb-grey mb-1">Mot de passe</label>
                    <input type="password" name="_password" id="password"
                           autocomplete="current-password" required
                           class="w-full rounded-md border border-gray-300 px-3 py-2 focus:border-sfb-green focus:ring-1 focus:ring-sfb-green outline-none">
                </div>

                <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

                <button type="submit"
                        class="w-full rounded-md bg-sfb-green px-4 py-2.5 text-white font-medium hover:bg-sfb-green-dark transition-colors cursor-pointer focus:outline-none focus:ring-2 focus:ring-sfb-green focus:ring-offset-1">
                    Me connecter
                </button>
            </form>
        </div>

        <div class="mt-4 rounded-md border border-blue-200 bg-blue-50 px-4 py-3 text-sm text-blue-800">
            <p class="font-medium">Compte de démonstration</p>
            <p class="mt-1 font-mono text-xs">demo@sfbois.com · demo</p>
        </div>
    </div>

    <div class="max-w-md mx-auto mt-10">
        {% include 'partials/_demo_notice.html.twig' %}
    </div>
{% endblock %}
